<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_notification_tree" model="ir.ui.view">
        <field name="name">dreezel.notification.tree</field>
        <field name="model">dreezel.notification</field>
        <field name="arch" type="xml">
            <tree string="Notifikasi" decoration-muted="is_read == True">
                <field name="notification_type" widget="badge"
                       string="Tipe"
                       decoration-danger="notification_type == 'low_stock'"
                       decoration-success="notification_type == 'goods_arrived'"/>
                <field name="title" string="Judul"/>
                <field name="date" string="Tanggal"/>
                <field name="ingredient_id" optional="show" string="Bahan Baku"/>
                <field name="order_id" optional="show" string="No. Pesanan"/>
                <field name="is_read" widget="boolean_toggle" string="Sudah Dibaca"/>
            </tree>
        </field>
    </record>

    <record id="view_notification_form" model="ir.ui.view">
        <field name="name">dreezel.notification.form</field>
        <field name="model">dreezel.notification</field>
        <field name="arch" type="xml">
            <form string="Notifikasi">
                <header>
                    <button name="action_mark_read" string="Tandai Sudah Dibaca"
                            type="object" invisible="is_read == True"/>
                    <button name="action_mark_unread" string="Tandai Belum Dibaca"
                            type="object" invisible="is_read == False"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="notification_type" string="Tipe Notifikasi"/>
                            <field name="title" string="Judul"/>
                            <field name="date" readonly="1" string="Tanggal"/>
                            <field name="is_read" string="Sudah Dibaca"/>
                        </group>
                        <group>
                            <field name="ingredient_id"
                                   string="Bahan Baku"
                                   invisible="notification_type != 'low_stock'"/>
                            <field name="order_id"
                                   string="No. Pesanan"
                                   invisible="notification_type != 'goods_arrived'"/>
                        </group>
                    </group>
                    <separator string="Pesan"/>
                    <field name="message" readonly="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_notification_search" model="ir.ui.view">
        <field name="name">dreezel.notification.search</field>
        <field name="model">dreezel.notification</field>
        <field name="arch" type="xml">
            <search string="Cari Notifikasi">
                <field name="title" string="Judul"/>
                <filter name="unread" string="Belum Dibaca" domain="[('is_read', '=', False)]"/>
                <filter name="low_stock" string="Stok Menipis"
                        domain="[('notification_type', '=', 'low_stock')]"/>
                <filter name="goods_arrived" string="Barang Tiba"
                        domain="[('notification_type', '=', 'goods_arrived')]"/>
                <group expand="0" string="Kelompokkan">
                    <filter name="group_type" string="Tipe"
                            context="{'group_by': 'notification_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_notification" model="ir.actions.act_window">
        <field name="name">Notifikasi</field>
        <field name="res_model">dreezel.notification</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_unread': 1}</field>
    </record>
</odoo>
