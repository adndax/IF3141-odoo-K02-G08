<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Root Application Menu -->
    <menuitem id="menu_root"
        name="Dreezel Coffee"
        sequence="1"
        web_icon="dreezel_coffee,static/description/icon.png"/>

    <!-- ============================================================
         1. DASHBOARD POS  (Kasir + Manajer)
         ============================================================ -->
    <menuitem id="menu_dashboard_pos"
        name="Dashboard POS"
        parent="menu_root"
        action="action_transaction_dashboard"
        sequence="1"
        groups="dreezel_coffee.group_kasir,dreezel_coffee.group_manager,base.group_system"/>

    <!-- ============================================================
         2. MANAJEMEN PRODUK DAN TRANSAKSI  (Manajer)
         ============================================================ -->
    <menuitem id="menu_produk_transaksi"
        name="Manajemen Produk dan Transaksi"
        parent="menu_root"
        sequence="2"
        groups="dreezel_coffee.group_manager,base.group_system"/>

    <menuitem id="menu_daftar_produk"
        name="Daftar Produk"
        parent="menu_produk_transaksi"
        action="action_product"
        sequence="1"
        groups="dreezel_coffee.group_manager,base.group_system"/>

    <menuitem id="menu_riwayat_transaksi"
        name="Riwayat Transaksi"
        parent="menu_produk_transaksi"
        action="action_transaction"
        sequence="2"
        groups="dreezel_coffee.group_manager,base.group_system"/>

    <!-- ============================================================
         3. MANAJEMEN BAHAN BAKU  (Manajer) — 3 submenu
         Notifikasi stok menipis menjadi indikator di Daftar Bahan Baku
         ============================================================ -->
    <menuitem id="menu_bahan_baku_root"
        name="Manajemen Bahan Baku"
        parent="menu_root"
        sequence="3"
        groups="dreezel_coffee.group_manager,base.group_system"/>

    <menuitem id="menu_daftar_bahan_baku"
        name="Daftar Bahan Baku"
        parent="menu_bahan_baku_root"
        action="action_ingredient"
        sequence="1"
        groups="dreezel_coffee.group_manager,base.group_system"/>

    <menuitem id="menu_pengadaan_bahan_baku"
        name="Pengadaan Bahan Baku"
        parent="menu_bahan_baku_root"
        action="action_pengadaan_bahan_baku"
        sequence="2"
        groups="dreezel_coffee.group_manager,base.group_system"/>

    <menuitem id="menu_vendor"
        name="Vendor"
        parent="menu_bahan_baku_root"
        action="action_vendor"
        sequence="3"
        groups="dreezel_coffee.group_manager,base.group_system"/>

    <!-- ============================================================
         4. LAPORAN PENJUALAN  (Manajer)
         ============================================================ -->
    <menuitem id="menu_laporan_penjualan"
        name="Laporan Penjualan"
        parent="menu_root"
        action="action_sales_report"
        sequence="4"
        groups="dreezel_coffee.group_manager,base.group_system"/>
</odoo>
