<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_transaction_pivot" model="ir.ui.view">
        <field name="name">dreezel.transaction.pivot</field>
        <field name="model">dreezel.transaction</field>
        <field name="arch" type="xml">
            <pivot string="Laporan Penjualan" disable_linking="True">
                <field name="date" type="row" interval="month" string="Periode"/>
                <field name="cashier_id" type="row" string="Kasir"/>
                <field name="payment_method" type="col" string="Metode Bayar"/>
                <field name="total" type="measure" string="Total Penjualan"/>
            </pivot>
        </field>
    </record>

    <record id="view_transaction_graph" model="ir.ui.view">
        <field name="name">dreezel.transaction.graph</field>
        <field name="model">dreezel.transaction</field>
        <field name="arch" type="xml">
            <graph string="Grafik Penjualan" type="bar">
                <field name="date" type="row" interval="day" string="Tanggal"/>
                <field name="total" type="measure" string="Total"/>
            </graph>
        </field>
    </record>

    <record id="action_sales_report" model="ir.actions.act_window">
        <field name="name">Laporan Penjualan</field>
        <field name="res_model">dreezel.transaction</field>
        <field name="view_mode">pivot,graph,tree</field>
        <field name="domain">[('state', '=', 'paid')]</field>
        <field name="context">{'search_default_this_month': 1}</field>
    </record>
</odoo>
