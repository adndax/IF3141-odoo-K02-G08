<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_product_tree" model="ir.ui.view">
        <field name="name">dreezel.product.tree</field>
        <field name="model">dreezel.product</field>
        <field name="arch" type="xml">
            <tree string="Daftar Produk"
                 
                  decoration-muted="not is_available">
                <field name="code" optional="show" string="Kode"/>
                <field name="name" string="Nama Produk"/>
                <field name="category_id" string="Kategori"/>
                <field name="price" string="Harga"/>
                <field name="is_available" widget="boolean_toggle" string="Tersedia"/>
            </tree>
        </field>
    </record>

    <record id="view_product_kanban" model="ir.ui.view">
        <field name="name">dreezel.product.kanban</field>
        <field name="model">dreezel.product</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column"
                    default_group_by="category_id"
                   >
                <field name="name"/>
                <field name="price"/>
                <field name="is_available"/>
                <field name="image"/>
                <field name="category_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <field name="image" widget="image" options="{'size': [64, 64]}"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <div class="o_kanban_tags_section">
                                    <field name="category_id"/>
                                </div>
                                <div>
                                    Rp <field name="price"/>
                                </div>
                                <div t-if="!record.is_available.value" class="text-muted">
                                    Tidak Tersedia
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_product_form" model="ir.ui.view">
        <field name="name">dreezel.product.form</field>
        <field name="model">dreezel.product</field>
        <field name="arch" type="xml">
            <form string="Produk">
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name" string="Nama Produk"/>
                        <h1><field name="name" placeholder="Nama Produk"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code" string="Kode"/>
                            <field name="category_id" string="Kategori"/>
                            <field name="price" string="Harga"/>
                        </group>
                        <group>
                            <field name="is_available" string="Tersedia"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Deskripsi">
                            <field name="description" placeholder="Deskripsi produk..."/>
                        </page>
                        <page string="Resep Bahan Baku">
                            <field name="ingredient_ids">
                                <tree editable="bottom">
                                    <field name="ingredient_id" string="Bahan Baku"/>
                                    <field name="quantity" string="Jumlah"/>
                                    <field name="unit" readonly="1" string="Satuan"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_product_search" model="ir.ui.view">
        <field name="name">dreezel.product.search</field>
        <field name="model">dreezel.product</field>
        <field name="arch" type="xml">
            <search string="Cari Produk">
                <field name="name" string="Nama"/>
                <field name="code" string="Kode"/>
                <field name="category_id" string="Kategori"/>
                <filter name="available" string="Tersedia" domain="[('is_available', '=', True)]"/>
                <filter name="unavailable" string="Tidak Tersedia" domain="[('is_available', '=', False)]"/>
                <group expand="0" string="Kelompokkan">
                    <filter name="group_category" string="Kategori" context="{'group_by': 'category_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_product" model="ir.actions.act_window">
        <field name="name">Daftar Produk</field>
        <field name="res_model">dreezel.product</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>
</odoo>
