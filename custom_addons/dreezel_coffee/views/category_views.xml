<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_category_tree" model="ir.ui.view">
        <field name="name">dreezel.category.tree</field>
        <field name="model">dreezel.category</field>
        <field name="arch" type="xml">
            <tree string="Kategori Produk">
                <field name="name" string="Kategori"/>
                <field name="product_count" string="Jumlah Produk"/>
            </tree>
        </field>
    </record>

    <record id="view_category_form" model="ir.ui.view">
        <field name="name">dreezel.category.form</field>
        <field name="model">dreezel.category</field>
        <field name="arch" type="xml">
            <form string="Kategori">
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Nama Kategori"/>
                        <h1><field name="name" placeholder="Nama Kategori"/></h1>
                    </div>
                    <group>
                        <field name="name" string="Kategori"/>
                        <field name="product_count" readonly="1" string="Jumlah Produk"/>
                    </group>
                    <separator string="Daftar Produk"/>
                    <field name="product_ids" readonly="1">
                        <tree>
                            <field name="name" string="Nama Produk"/>
                            <field name="price" string="Harga"/>
                            <field name="is_available" string="Tersedia"/>
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_category" model="ir.actions.act_window">
        <field name="name">Kategori Produk</field>
        <field name="res_model">dreezel.category</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
