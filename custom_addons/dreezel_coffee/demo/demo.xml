<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>

        <!-- Categories -->
        <record id="cat_coffee" model="dreezel.category">
            <field name="name" type="char">Coffee</field>
        </record>
        <record id="cat_tea" model="dreezel.category">
            <field name="name" type="char">Tea</field>
        </record>
        <record id="cat_dessert" model="dreezel.category">
            <field name="name" type="char">Dessert</field>
        </record>
        <record id="cat_food" model="dreezel.category">
            <field name="name" type="char">Food</field>
        </record>

        <!-- Vendors -->
        <record id="vendor_prima" model="dreezel.vendor">
            <field name="name" type="char">Prima Supplier</field>
            <field name="contact" type="char">081234567890</field>
            <field name="address" type="char">Jl. Raya No. 1, Bandung</field>
            <field name="is_active" eval="True"/>
        </record>
        <record id="vendor_segar" model="dreezel.vendor">
            <field name="name" type="char">Segar Jaya</field>
            <field name="contact" type="char">089876543210</field>
            <field name="address" type="char">Jl. Pasar Baru No. 5, Bandung</field>
            <field name="is_active" eval="True"/>
        </record>

        <!-- Ingredients -->
        <record id="ing_espresso" model="dreezel.ingredient">
            <field name="name" type="char">Espresso Shot</field>
            <field name="code" type="char">ING-001</field>
            <field name="unit" type="char">shot</field>
            <field name="stock" eval="100.0"/>
            <field name="min_stock" eval="10.0"/>
            <field name="price_per_unit" eval="2000.0"/>
            <field name="vendor_id" ref="vendor_prima"/>
        </record>
        <record id="ing_milk" model="dreezel.ingredient">
            <field name="name" type="char">Fresh Milk</field>
            <field name="code" type="char">ING-002</field>
            <field name="unit" type="char">ml</field>
            <field name="stock" eval="5000.0"/>
            <field name="min_stock" eval="500.0"/>
            <field name="price_per_unit" eval="15.0"/>
            <field name="vendor_id" ref="vendor_segar"/>
        </record>
        <record id="ing_sugar" model="dreezel.ingredient">
            <field name="name" type="char">Sugar Syrup</field>
            <field name="code" type="char">ING-003</field>
            <field name="unit" type="char">ml</field>
            <field name="stock" eval="2000.0"/>
            <field name="min_stock" eval="200.0"/>
            <field name="price_per_unit" eval="5.0"/>
            <field name="vendor_id" ref="vendor_prima"/>
        </record>
        <record id="ing_tea_bag" model="dreezel.ingredient">
            <field name="name" type="char">Tea Bag</field>
            <field name="code" type="char">ING-004</field>
            <field name="unit" type="char">sachet</field>
            <field name="stock" eval="200.0"/>
            <field name="min_stock" eval="20.0"/>
            <field name="price_per_unit" eval="1500.0"/>
            <field name="vendor_id" ref="vendor_segar"/>
        </record>
        <record id="ing_choco_powder" model="dreezel.ingredient">
            <field name="name" type="char">Chocolate Powder</field>
            <field name="code" type="char">ING-005</field>
            <field name="unit" type="char">gram</field>
            <field name="stock" eval="3000.0"/>
            <field name="min_stock" eval="300.0"/>
            <field name="price_per_unit" eval="50.0"/>
            <field name="vendor_id" ref="vendor_prima"/>
        </record>
        <record id="ing_ice" model="dreezel.ingredient">
            <field name="name" type="char">Ice Cubes</field>
            <field name="code" type="char">ING-006</field>
            <field name="unit" type="char">gram</field>
            <field name="stock" eval="10000.0"/>
            <field name="min_stock" eval="1000.0"/>
            <field name="price_per_unit" eval="1.0"/>
            <field name="vendor_id" ref="vendor_segar"/>
        </record>

        <!-- Products -->
        <record id="prod_americano" model="dreezel.product">
            <field name="name" type="char">Americano</field>
            <field name="code" type="char">DRZ-001</field>
            <field name="category_id" ref="cat_coffee"/>
            <field name="price" eval="25000.0"/>
            <field name="description" type="char">Classic black coffee with water</field>
            <field name="is_available" eval="True"/>
        </record>
        <record id="prod_latte" model="dreezel.product">
            <field name="name" type="char">Cafe Latte</field>
            <field name="code" type="char">DRZ-002</field>
            <field name="category_id" ref="cat_coffee"/>
            <field name="price" eval="32000.0"/>
            <field name="description" type="char">Espresso with steamed milk</field>
            <field name="is_available" eval="True"/>
        </record>
        <record id="prod_mocha" model="dreezel.product">
            <field name="name" type="char">Mocha</field>
            <field name="code" type="char">DRZ-003</field>
            <field name="category_id" ref="cat_coffee"/>
            <field name="price" eval="35000.0"/>
            <field name="description" type="char">Espresso with chocolate and milk</field>
            <field name="is_available" eval="True"/>
        </record>
        <record id="prod_matcha_latte" model="dreezel.product">
            <field name="name" type="char">Matcha Latte</field>
            <field name="code" type="char">DRZ-004</field>
            <field name="category_id" ref="cat_tea"/>
            <field name="price" eval="30000.0"/>
            <field name="description" type="char">Matcha green tea with milk</field>
            <field name="is_available" eval="True"/>
        </record>
        <record id="prod_ice_choco" model="dreezel.product">
            <field name="name" type="char">Ice Chocolate</field>
            <field name="code" type="char">DRZ-005</field>
            <field name="category_id" ref="cat_dessert"/>
            <field name="price" eval="28000.0"/>
            <field name="description" type="char">Cold chocolate drink</field>
            <field name="is_available" eval="True"/>
        </record>

        <!-- Product Ingredients (Recipe) -->
        <record id="recipe_americano_espresso" model="dreezel.product.ingredient">
            <field name="product_id" ref="prod_americano"/>
            <field name="ingredient_id" ref="ing_espresso"/>
            <field name="quantity" eval="2.0"/>
        </record>
        <record id="recipe_latte_espresso" model="dreezel.product.ingredient">
            <field name="product_id" ref="prod_latte"/>
            <field name="ingredient_id" ref="ing_espresso"/>
            <field name="quantity" eval="2.0"/>
        </record>
        <record id="recipe_latte_milk" model="dreezel.product.ingredient">
            <field name="product_id" ref="prod_latte"/>
            <field name="ingredient_id" ref="ing_milk"/>
            <field name="quantity" eval="150.0"/>
        </record>
        <record id="recipe_mocha_espresso" model="dreezel.product.ingredient">
            <field name="product_id" ref="prod_mocha"/>
            <field name="ingredient_id" ref="ing_espresso"/>
            <field name="quantity" eval="2.0"/>
        </record>
        <record id="recipe_mocha_milk" model="dreezel.product.ingredient">
            <field name="product_id" ref="prod_mocha"/>
            <field name="ingredient_id" ref="ing_milk"/>
            <field name="quantity" eval="100.0"/>
        </record>
        <record id="recipe_mocha_choco" model="dreezel.product.ingredient">
            <field name="product_id" ref="prod_mocha"/>
            <field name="ingredient_id" ref="ing_choco_powder"/>
            <field name="quantity" eval="20.0"/>
        </record>
        <record id="recipe_ice_choco_milk" model="dreezel.product.ingredient">
            <field name="product_id" ref="prod_ice_choco"/>
            <field name="ingredient_id" ref="ing_milk"/>
            <field name="quantity" eval="200.0"/>
        </record>
        <record id="recipe_ice_choco_powder" model="dreezel.product.ingredient">
            <field name="product_id" ref="prod_ice_choco"/>
            <field name="ingredient_id" ref="ing_choco_powder"/>
            <field name="quantity" eval="25.0"/>
        </record>
        <record id="recipe_ice_choco_ice" model="dreezel.product.ingredient">
            <field name="product_id" ref="prod_ice_choco"/>
            <field name="ingredient_id" ref="ing_ice"/>
            <field name="quantity" eval="150.0"/>
        </record>

        <!-- Discounts -->
        <record id="disc_happy_hour" model="dreezel.discount">
            <field name="code" type="char">HAPPYHOUR</field>
            <field name="discount_type" type="char">percentage</field>
            <field name="value" eval="15.0"/>
            <field name="date_start" eval="'2026-01-01'"/>
            <field name="date_end" eval="'2026-12-31'"/>
            <field name="is_active" eval="True"/>
        </record>
        <record id="disc_new_member" model="dreezel.discount">
            <field name="code" type="char">NEWMEMBER</field>
            <field name="discount_type" type="char">fixed</field>
            <field name="value" eval="5000.0"/>
            <field name="date_start" eval="'2026-01-01'"/>
            <field name="date_end" eval="'2026-12-31'"/>
            <field name="is_active" eval="True"/>
        </record>

    </data>
</odoo>
