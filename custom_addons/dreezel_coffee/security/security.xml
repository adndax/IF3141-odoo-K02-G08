<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="module_category_dreezel" model="ir.module.category">
        <field name="name">Dreezel Coffee</field>
        <field name="sequence">1</field>
    </record>

    <record id="group_kasir" model="res.groups">
        <field name="name">Kasir</field>
        <field name="category_id" ref="module_category_dreezel"/>
    </record>

    <record id="group_operasional" model="res.groups">
        <field name="name">Tim Operasional</field>
        <field name="category_id" ref="module_category_dreezel"/>
    </record>

    <record id="group_manager" model="res.groups">
        <field name="name">Manajer</field>
        <field name="category_id" ref="module_category_dreezel"/>
        <field name="implied_ids" eval="[(4, ref('group_kasir')), (4, ref('group_operasional'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <record id="base.group_system" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_manager'))]"/>
    </record>
</odoo>
